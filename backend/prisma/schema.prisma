datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  owner
  member
}

model Planner {
  id          String    @id @default(uuid())
  title       String    @db.VarChar(100) 
  share_code  String    @unique @db.VarChar(36)
  is_deleted  Boolean   @default(false)
  deleted_at  DateTime?
  created_at  DateTime  @default(now())
  
  participants Participant[]
  days         Day[]
  messages     Message[]

  @@map("Planner") 
}

model Participant {
  id            String    @id @default(uuid())
  planner_id    String
  name          String    @db.VarChar(30)
  password_hash String    @db.VarChar(255)
  role          Role      @default(member) 
  joined_at     DateTime  @default(now())

  planner       Planner   @relation(fields: [planner_id], references: [id], onDelete: Cascade)
  schedules     Schedule[] 
  messages      Message[]

  @@unique([planner_id, name]) 
  @@map("Participant")
}

model Day {
  id         String     @id @default(uuid())
  planner_id String
  day_number Int
  label      String     @db.VarChar(20)

  planner    Planner    @relation(fields: [planner_id], references: [id], onDelete: Cascade)
  schedules  Schedule[]

  @@map("Day")
}

model Schedule {
  id          String       @id @default(uuid())
  day_id      String
  start_time  String       @db.VarChar(10)  // "09:00"
  end_time    String       @db.VarChar(10)  // "09:00"
  place_name  String?      @db.VarChar(100) 
  place_lat   Decimal?     @db.Decimal(10, 7) 
  place_lng   Decimal?     @db.Decimal(10, 7)
  content     String?      @db.Text
  created_by  String      
  
  created_at  DateTime     @default(now())
  updated_at  DateTime     @updatedAt

  day         Day          @relation(fields: [day_id], references: [id], onDelete: Cascade)
  author      Participant? @relation(fields: [created_by], references: [id], onDelete: Restrict) 

  @@map("Schedule")
}

model Message {
  id             String      @id @default(uuid())
  planner_id     String
  participant_id String
  content        String      @db.Text
  created_at     DateTime    @default(now())

  planner        Planner     @relation(fields: [planner_id], references: [id], onDelete: Cascade)
  participant    Participant @relation(fields: [participant_id], references: [id], onDelete: Cascade)

  @@map("Message")
}